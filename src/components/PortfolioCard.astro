---
interface Props {
  title: string;
  description: string;
  category: string;
  cover: string;
  slug: string;
}

const { title, description, category, cover, slug } = Astro.props;
---

<a href={`/portfolio/${slug}`} class="portfolio-card">
  <div class="card-image">
    <img src={cover} alt={title} loading="lazy" onerror="this.style.display='none'; this.parentElement.classList.add('placeholder-img'); this.parentElement.textContent='Photo'" />
  </div>
  <div class="card-content">
    <span class="card-category">{category}</span>
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</a>

<style>
  .portfolio-card {
    display: block;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .portfolio-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
  }

  .card-image {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--color-bg-elevated);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .portfolio-card:hover .card-image img {
    transform: scale(1.03);
  }

  .card-image.placeholder-img {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .card-content {
    padding: var(--space-lg);
  }

  .card-category {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    display: block;
    margin-bottom: var(--space-sm);
  }

  .card-content h3 {
    color: var(--color-white);
    margin-bottom: var(--space-sm);
    font-size: 1.3rem;
  }

  .card-content p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }
</style>
