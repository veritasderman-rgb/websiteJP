---
interface Props {
  active?: string;
}

const { active = 'all' } = Astro.props;

const categories = [
  { value: 'all', label: 'Vše', href: '/portfolio' },
  { value: 'architecture', label: 'Architektura', href: '/portfolio/architecture' },
  { value: 'events', label: 'Akce', href: '/portfolio/events' },
  { value: 'portraits', label: 'Portréty', href: '/portfolio/portraits' },
  { value: 'landscape', label: 'Krajina', href: '/portfolio/landscape' },
];
---

<nav class="gallery-filter" aria-label="Filtr kategorií">
  {categories.map((cat) => (
    <a
      href={cat.href}
      class:list={['gallery-filter__link', { active: active === cat.value }]}
    >
      {cat.label}
    </a>
  ))}
</nav>

<style>
  .gallery-filter {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 3rem;
  }

  .gallery-filter__link {
    padding: 0.4rem 1.25rem;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    font-size: 0.75rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border-radius: var(--radius-sm);
    transition: all var(--transition);
  }

  .gallery-filter__link:hover,
  .gallery-filter__link.active {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
