---
interface Photo {
  src: string;
  alt: string;
  title?: string;
  category?: string;
  href?: string;
  count?: number;
  date?: string;
}

interface Props {
  photos: Photo[];
  masonry?: boolean;
}

const { photos, masonry = false } = Astro.props;
---

<div class:list={['photo-grid', { 'photo-grid--masonry': masonry }]}>
  {photos.map((photo) => (
    photo.href ? (
      <a href={photo.href} class="photo-grid__item">
        <img
          src={photo.src}
          alt={photo.alt}
          loading="lazy"
          width="800"
          height="600"
        />
        <div class="photo-grid__overlay">
          {photo.category && <span class="photo-grid__category">{photo.category}</span>}
          {photo.title && <h3 class="photo-grid__title">{photo.title}</h3>}
          {(photo.count || photo.date) && (
            <span class="photo-grid__meta">
              {photo.count && `${photo.count} fotek`}
              {photo.count && photo.date && ' — '}
              {photo.date}
            </span>
          )}
          <div class="photo-grid__line"></div>
        </div>
      </a>
    ) : (
      <div class="photo-grid__item photo-grid__item--lightbox" data-index={photos.indexOf(photo)}>
        <img
          src={photo.src}
          alt={photo.alt}
          loading="lazy"
          width="800"
          height="600"
        />
      </div>
    )
  ))}
</div>

<style>
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1rem;
  }

  .photo-grid--masonry {
    grid-template-columns: repeat(3, 1fr);
  }

  @media (max-width: 1024px) {
    .photo-grid--masonry {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .photo-grid,
    .photo-grid--masonry {
      grid-template-columns: 1fr;
    }
  }

  .photo-grid__item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 2;
    display: block;
    background: var(--color-surface);
    cursor: pointer;
  }

  .photo-grid__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1), opacity var(--transition);
  }

  .photo-grid__item:hover img {
    transform: scale(1.03);
  }

  .photo-grid__overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 8, 0.55);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
    opacity: 0;
    transition: opacity var(--transition);
  }

  .photo-grid__item:hover .photo-grid__overlay {
    opacity: 1;
  }

  .photo-grid__category {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: 0.35rem;
  }

  .photo-grid__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.15rem;
    color: var(--color-text);
    line-height: 1.3;
    margin-bottom: 0.25rem;
  }

  .photo-grid__meta {
    font-size: 0.7rem;
    color: var(--color-muted);
    letter-spacing: 0.05em;
  }

  .photo-grid__line {
    width: 2rem;
    height: 1px;
    background: var(--color-accent);
    margin-top: 0.75rem;
    transition: width var(--transition);
  }

  .photo-grid__item:hover .photo-grid__line {
    width: 3rem;
  }
</style>
