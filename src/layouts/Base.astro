---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  transparentNav?: boolean;
}

const { title, description = '', transparentNav = false } = Astro.props;
const pageTitle = title ? `${title} — Josef Pavlovic` : 'Josef Pavlovic — Fotografie';
---

<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={description || 'Fotografické portfolio Josefa Pavlovice — architektura, reportáže, portréty, krajina.'} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
</head>
<body>
  <a href="#main-content" class="skip-to-content">Přejít na obsah</a>
  <Nav transparent={transparentNav} />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
</body>
</html>
