---
import Base from '../../layouts/Base.astro';
import GalleryFilter from '../../components/GalleryFilter.astro';
import PhotoGrid from '../../components/PhotoGrid.astro';
import { getCollection } from 'astro:content';

const categoryLabels: Record<string, string> = {
  architecture: 'Architektura',
  events: 'Akce',
  portraits: 'Portréty',
  landscape: 'Krajina',
  weddings: 'Svatby',
};

const allEntries = await getCollection('gallery', ({ data }) => !data.draft);
const sorted = allEntries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Portfolio" description="Ukázky z mé práce — svatby, architektura, reportáže, portréty, krajina.">
  <div class="section--sm">
    <div class="container">
      <h1 class="page-title">Portfolio</h1>
      <GalleryFilter active="all" />
      <PhotoGrid
        photos={sorted.map((e) => ({
          src: e.data.cover,
          alt: e.data.title,
          title: e.data.title,
          category: categoryLabels[e.data.category] || e.data.category,
          href: `/portfolio/${e.id}`,
          count: e.data.images.length,
          date: e.data.date.toLocaleDateString('cs-CZ', { year: 'numeric', month: 'long' }),
        }))}
      />
    </div>
  </div>
</Base>

<style>
  .page-title {
    text-align: center;
    padding-top: calc(var(--header-height) + 3rem);
    margin-bottom: 1rem;
    font-style: italic;
  }
</style>
