---
import Base from '../../layouts/Base.astro';
import GalleryFilter from '../../components/GalleryFilter.astro';
import PhotoGrid from '../../components/PhotoGrid.astro';
import { getCollection } from 'astro:content';

const categoryLabels: Record<string, string> = {
  architecture: 'Architektura',
  events: 'Akce',
  portraits: 'Portréty',
  landscape: 'Krajina',
  weddings: 'Svatby',
};

export async function getStaticPaths() {
  return [
    { params: { category: 'architecture' } },
    { params: { category: 'events' } },
    { params: { category: 'portraits' } },
    { params: { category: 'landscape' } },
    { params: { category: 'weddings' } },
  ];
}

const { category } = Astro.params;
const allEntries = await getCollection('gallery', ({ data }) => !data.draft);
const filtered = allEntries
  .filter((e) => e.data.category === category)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const label = categoryLabels[category!] || category;
---

<Base title={label} description={`Portfolio — ${label}`}>
  <div class="section--sm">
    <div class="container">
      <h1 class="page-title">{label}</h1>
      <GalleryFilter active={category} />
      <PhotoGrid
        photos={filtered.map((e) => ({
          src: e.data.cover,
          alt: e.data.title,
          title: e.data.title,
          category: categoryLabels[e.data.category] || e.data.category,
          href: `/portfolio/${e.id}`,
          count: e.data.images.length,
          date: e.data.date.toLocaleDateString('cs-CZ', { year: 'numeric', month: 'long' }),
        }))}
      />
    </div>
  </div>
</Base>

<style>
  .page-title {
    text-align: center;
    padding-top: calc(var(--header-height) + 3rem);
    margin-bottom: 1rem;
    font-style: italic;
  }
</style>
