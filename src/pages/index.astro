---
import Base from '../layouts/Base.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import { getCollection } from 'astro:content';

const allEntries = await getCollection('gallery', ({ data }) => !data.draft);
const sorted = allEntries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Hero: latest featured photo
const heroEntry = sorted.find((e) => e.data.featured) || sorted[0];

// Featured grid: up to 9 featured
const featured = sorted.filter((e) => e.data.featured).slice(0, 9);

// Category cards
const categoryLabels: Record<string, string> = {
  architecture: 'Architektura & nemovitosti',
  events: 'Akce & reportáže',
  portraits: 'Portréty & akty',
  landscape: 'Krajina & street',
};

const categories = (['architecture', 'events', 'portraits', 'landscape'] as const).map((cat) => {
  const latest = sorted.find((e) => e.data.category === cat);
  return {
    value: cat,
    label: categoryLabels[cat],
    cover: latest?.data.cover || '',
  };
});
---

<Base transparentNav={true}>
  <!-- HERO -->
  <section class="hero" style={`background-image: url('${heroEntry?.data.cover || ''}')`}>
    <div class="hero__noise"></div>
    <div class="hero__content">
      <h1 class="hero__name">Josef Pavlovic</h1>
      <p class="hero__tagline">Fotografie</p>
    </div>
    <a href="#featured" class="hero__scroll" aria-label="Scroll dolů">
      <span class="hero__arrow"></span>
    </a>
  </section>

  <!-- FEATURED -->
  <section class="section" id="featured">
    <div class="container">
      <h2 class="section__heading">Vybrané práce</h2>
      <PhotoGrid
        masonry={true}
        photos={featured.map((e) => ({
          src: e.data.cover,
          alt: e.data.title,
          title: e.data.title,
          category: categoryLabels[e.data.category] || e.data.category,
          href: `/portfolio/${e.id}`,
          count: e.data.images.length,
        }))}
      />
    </div>
  </section>

  <!-- CATEGORIES -->
  <section class="section--sm categories">
    <div class="container">
      <h2 class="section__heading">Kategorie</h2>
      <div class="categories__grid">
        {categories.map((cat) => (
          <a href={`/portfolio/${cat.value}`} class="categories__card">
            <img src={cat.cover} alt={cat.label} loading="lazy" width="600" height="400" />
            <span class="categories__label">{cat.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  /* HERO */
  .hero {
    position: relative;
    height: 100vh;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .hero__noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.06'/%3E%3C/svg%3E");
    background-repeat: repeat;
    pointer-events: none;
    z-index: 1;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 10, 8, 0.3) 0%,
      rgba(10, 10, 8, 0.1) 40%,
      rgba(10, 10, 8, 0.6) 100%
    );
    z-index: 1;
  }

  .hero__content {
    position: relative;
    z-index: 2;
  }

  .hero__name {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-family: var(--font-display);
    font-weight: 400;
    color: var(--color-text);
    letter-spacing: 0.02em;
    margin-bottom: 0.5rem;
  }

  .hero__tagline {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--color-accent);
  }

  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    color: var(--color-muted);
    text-decoration: none;
  }

  .hero__arrow {
    display: block;
    width: 1px;
    height: 40px;
    background: var(--color-muted);
    position: relative;
    animation: scrollPulse 2s ease-in-out infinite;
  }

  .hero__arrow::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: -3px;
    width: 7px;
    height: 7px;
    border-bottom: 1px solid var(--color-muted);
    border-right: 1px solid var(--color-muted);
    transform: rotate(45deg);
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: translateY(0); }
    50% { opacity: 1; transform: translateY(6px); }
  }

  /* SECTIONS */
  .section__heading {
    text-align: center;
    margin-bottom: 3.5rem;
    font-style: italic;
    color: var(--color-text);
  }

  /* CATEGORIES */
  .categories__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  @media (max-width: 1024px) {
    .categories__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .categories__grid {
      grid-template-columns: 1fr;
    }
  }

  .categories__card {
    position: relative;
    display: block;
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .categories__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .categories__card:hover img {
    transform: scale(1.04);
  }

  .categories__label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.25rem;
    background: linear-gradient(to top, rgba(10, 10, 8, 0.8), transparent);
    font-size: 0.8rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text);
  }
</style>
