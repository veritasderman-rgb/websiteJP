---
import Base from '../layouts/Base.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import { getCollection } from 'astro:content';

const allEntries = await getCollection('gallery', ({ data }) => !data.draft);
const sorted = allEntries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Hero: latest featured photo
const heroEntry = sorted.find((e) => e.data.featured) || sorted[0];

// Featured grid: up to 6 featured
const featured = sorted.filter((e) => e.data.featured).slice(0, 6);

// Category cards
const categoryLabels: Record<string, string> = {
  weddings: 'Svatby',
  architecture: 'Architektura & nemovitosti',
  events: 'Akce & reportáže',
  portraits: 'Portréty & akty',
  landscape: 'Krajina & street',
};

const categories = (['weddings', 'architecture', 'events', 'portraits', 'landscape'] as const).map((cat) => {
  const latest = sorted.find((e) => e.data.category === cat);
  return {
    value: cat,
    label: categoryLabels[cat],
    cover: latest?.data.cover || '',
  };
});
---

<Base transparentNav={true}>
  <!-- HERO -->
  <section class="hero" style={`background-image: url('${heroEntry?.data.cover || ''}')`}>
    <div class="hero__noise"></div>
    <div class="hero__content">
      <p class="hero__pre">Svatební & portrétní fotograf — Praha</p>
      <h1 class="hero__name">Josef Pavlovic</h1>
      <p class="hero__text">Zachytím vaše nejkrásnější momenty. Svatby, portréty, rodinné focení a více.</p>
      <div class="hero__actions">
        <a href="/cenik" class="hero__btn hero__btn--primary">Zobrazit ceník</a>
        <a href="/contact" class="hero__btn hero__btn--secondary">Nezávazná poptávka</a>
      </div>
    </div>
    <a href="#services" class="hero__scroll" aria-label="Scroll dolů">
      <span class="hero__arrow"></span>
    </a>
  </section>

  <!-- SERVICES -->
  <section class="services" id="services">
    <div class="container">
      <h2 class="section__heading">Co nabízím</h2>
      <div class="services__grid">
        <div class="services__card">
          <h3>Svatby</h3>
          <p>Celý váš svatební den zachycený přirozeně a s citem. Od příprav až po první tanec.</p>
          <span class="services__price">od 10 000 Kč</span>
        </div>
        <div class="services__card">
          <h3>Portréty</h3>
          <p>Profesionální portréty pro osobní brand, LinkedIn nebo jen tak pro radost.</p>
          <span class="services__price">od 3 500 Kč</span>
        </div>
        <div class="services__card">
          <h3>Architektura</h3>
          <p>Interiéry, exteriéry, realitní fotografie. Unikátní pohled na prostor.</p>
          <span class="services__price">od 5 000 Kč</span>
        </div>
        <div class="services__card">
          <h3>Akce & reportáže</h3>
          <p>Konference, firemní akce, koncerty. Energie okamžiku zachycená na film.</p>
          <span class="services__price">od 5 000 Kč</span>
        </div>
      </div>
      <div class="services__cta">
        <a href="/cenik" class="hero__btn hero__btn--secondary">Kompletní ceník</a>
      </div>
    </div>
  </section>

  <!-- FEATURED PORTFOLIO -->
  <section class="section" id="featured">
    <div class="container">
      <h2 class="section__heading">Z mého portfolia</h2>
      <PhotoGrid
        masonry={true}
        photos={featured.map((e) => ({
          src: e.data.cover,
          alt: e.data.title,
          title: e.data.title,
          category: categoryLabels[e.data.category] || e.data.category,
          href: `/portfolio/${e.id}`,
          count: e.data.images.length,
        }))}
      />
      <div class="services__cta">
        <a href="/portfolio" class="hero__btn hero__btn--secondary">Celé portfolio</a>
      </div>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section class="section--sm categories">
    <div class="container">
      <h2 class="section__heading">Kategorie</h2>
      <div class="categories__grid">
        {categories.map((cat) => (
          <a href={`/portfolio/${cat.value}`} class:list={['categories__card', { 'categories__card--featured': cat.value === 'weddings' }]}>
            <img src={cat.cover} alt={cat.label} loading="lazy" width="600" height="400" />
            <span class="categories__label">{cat.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="container">
      <h2>Hledáte fotografa na svatbu?</h2>
      <p>Napište mi a nezávazně probereme vaše představy. Termíny se plní rychle — rezervujte si svůj den včas.</p>
      <a href="/contact" class="hero__btn hero__btn--primary">Kontaktovat</a>
    </div>
  </section>
</Base>

<style>
  /* HERO */
  .hero {
    position: relative;
    height: 100vh;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .hero__noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.06'/%3E%3C/svg%3E");
    background-repeat: repeat;
    pointer-events: none;
    z-index: 1;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 10, 8, 0.35) 0%,
      rgba(10, 10, 8, 0.2) 40%,
      rgba(10, 10, 8, 0.7) 100%
    );
    z-index: 1;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    max-width: 650px;
    padding: 0 2rem;
  }

  .hero__pre {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .hero__name {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-family: var(--font-display);
    font-weight: 400;
    color: var(--color-text);
    letter-spacing: 0.02em;
    margin-bottom: 1rem;
  }

  .hero__text {
    font-size: 1.1rem;
    color: var(--color-muted);
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero__btn {
    display: inline-block;
    padding: 0.85rem 2.5rem;
    font-size: 0.78rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: var(--radius-sm);
    transition: all var(--transition);
  }

  .hero__btn--primary {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .hero__btn--primary:hover {
    background: var(--color-accent-dim);
    color: var(--color-bg);
  }

  .hero__btn--secondary {
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
  }

  .hero__btn--secondary:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    color: var(--color-muted);
    text-decoration: none;
  }

  .hero__arrow {
    display: block;
    width: 1px;
    height: 40px;
    background: var(--color-muted);
    position: relative;
    animation: scrollPulse 2s ease-in-out infinite;
  }

  .hero__arrow::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: -3px;
    width: 7px;
    height: 7px;
    border-bottom: 1px solid var(--color-muted);
    border-right: 1px solid var(--color-muted);
    transform: rotate(45deg);
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: translateY(0); }
    50% { opacity: 1; transform: translateY(6px); }
  }

  /* SECTIONS */
  .section__heading {
    text-align: center;
    margin-bottom: 3.5rem;
    font-style: italic;
    color: var(--color-text);
  }

  /* SERVICES */
  .services {
    padding: 120px 0;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    max-width: 950px;
    margin: 0 auto;
  }

  .services__card {
    padding: 2rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    border-radius: var(--radius-md);
    transition: border-color var(--transition);
  }

  .services__card:hover {
    border-color: var(--color-accent);
  }

  .services__card h3 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.15rem;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .services__card p {
    color: var(--color-muted);
    font-size: 0.85rem;
    line-height: 1.65;
    margin-bottom: 1rem;
  }

  .services__price {
    font-family: var(--font-display);
    color: var(--color-accent);
    font-size: 1.05rem;
  }

  .services__cta {
    text-align: center;
    margin-top: 3rem;
  }

  /* CATEGORIES */
  .categories__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  @media (max-width: 1024px) {
    .categories__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .categories__grid {
      grid-template-columns: 1fr;
    }
  }

  .categories__card {
    position: relative;
    display: block;
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .categories__card--featured {
    grid-column: span 2;
    aspect-ratio: 2 / 1;
  }

  @media (max-width: 640px) {
    .categories__card--featured {
      grid-column: span 1;
      aspect-ratio: 4 / 3;
    }
  }

  .categories__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .categories__card:hover img {
    transform: scale(1.04);
  }

  .categories__label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.25rem;
    background: linear-gradient(to top, rgba(10, 10, 8, 0.8), transparent);
    font-size: 0.8rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text);
  }

  /* CTA */
  .cta {
    text-align: center;
    padding: 120px 2rem;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
  }

  .cta h2 {
    font-style: italic;
    margin-bottom: 0.75rem;
  }

  .cta p {
    color: var(--color-muted);
    font-size: 1rem;
    max-width: 550px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }
</style>
