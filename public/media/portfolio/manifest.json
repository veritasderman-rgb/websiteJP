{
  "categories": {
    "mista-architektura": {
      "title": "Místa a architektura",
      "description": "Čisté kompozice lázeňských domů, kolonád, sakrálních detailů a městských struktur. Kategorie ukazuje cit pro prostor, rytmus linií a světlo v architektuře."
    },
    "krajina-atmosfera": {
      "title": "Krajina a atmosféra",
      "description": "Tiché zimní a podzimní scenérie, lesy, voda, mlha a letecké pohledy. Výběr staví na náladě, barvě a výrazném světelném okamžiku."
    },
    "portret-lifestyle": {
      "title": "Portrét a lifestyle",
      "description": "Přirozené portréty a stylizované série s důrazem na výraz, prostředí a jemnou práci se světlem. Hodí se jako lidská, civilní část portfolia."
    },
    "fine-art-akt": {
      "title": "Fine art / akt",
      "description": "Výtvarně laděné portréty a aktové kompozice v historických interiérech i exteriérech. Pro veřejný web doporučuji držet tuto kategorii odděleně a uvádět ji jen tam, kde odpovídá cílovému publiku."
    },
    "svatba-reportaz": {
      "title": "Svatba a reportáž",
      "description": "Výběr z celodenní svatební série: portréty páru, dokumentární momenty, detaily a atmosféra hostiny. Kategorie ukazuje schopnost vyprávět událost v obrazech."
    }
  },
